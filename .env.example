# HiClaw Controller endpoint (used by server-side proxy)
HICLAW_CONTROLLER_URL=http://127.0.0.1:8090

# Higress Console endpoint (for shared authentication with Higress).
# When set, login is proxied to Higress Console; otherwise a local user store is used.
# HICLAW_AI_GATEWAY_ADMIN_URL=http://127.0.0.1:8001

# Optional: browser-facing controller URL default (can be overridden in UI)
NEXT_PUBLIC_HICLAW_CONTROLLER_URL=http://127.0.0.1:8090

# Authentication to HiClaw Controller.
# Prefer HICLAW_AUTH_TOKEN_FILE for rotated ServiceAccount tokens.
# HICLAW_AUTH_TOKEN=
HICLAW_AUTH_TOKEN_FILE=/var/run/hiclaw/cli-token

# Matrix homeserver URL default (can be overridden in UI)
NEXT_PUBLIC_MATRIX_API_URL=http://127.0.0.1:6167

# Matrix homeserver whitelist for the proxy (comma-separated hostnames)
MATRIX_HOMESERVER_ALLOWLIST=matrix.org,example.com

# Base path when embedded as a sub-application in HiClaw.
# Leave empty for standalone root deployment.
NEXT_PUBLIC_BASE_PATH=/dashboard

# Optional: force deployment mode for menu filtering.
# When unset, mode is auto-detected from Controller API or K8s serviceaccount.
# HICLAW_DEPLOYMENT_MODE=embedded
